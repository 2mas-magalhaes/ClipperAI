# ClipperAI Configuration

# Download Settings
YOUTUBE_OUTPUT_DIR=downloads/
AUDIO_OUTPUT_DIR=audio/
VIDEO_OUTPUT_DIR=video/

# Transcription Settings
WHISPER_MODEL=base
WHISPER_LANGUAGE=pt
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# LLM Settings
OLLAMA_MODEL=llama2
OLLAMA_API_URL=http://localhost:11434
OLLAMA_TIMEOUT=300

# Optional: multiple Google OAuth credential files for rotation
# Separate paths with semicolons on Windows or colons on macOS/Linux.
GOOGLE_CREDENTIALS_FILES=

# Clip Selection Settings
MIN_CLIP_DURATION=30
MAX_CLIP_DURATION=120
NUM_CLIPS_TO_IDENTIFY=5

# Video Editing Settings
OUTPUT_RESOLUTION=1080p
OUTPUT_FORMAT=vertical

# GPU Settings
USE_GPU=true
CUDA_VISIBLE_DEVICES=0
