# ClipAI local configuration
# Copy this file to .env and fill only the values you need.
# This repository is intended as a local automation demo, so keep all secrets local.
# Never commit .env, OAuth client files, tokens, or generated databases.

# Storage paths
YOUTUBE_OUTPUT_DIR=downloads/
AUDIO_OUTPUT_DIR=downloads/
VIDEO_OUTPUT_DIR=downloads/

# Faster-Whisper transcription
WHISPER_MODEL=base
WHISPER_LANGUAGE=pt
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Ollama local LLM
OLLAMA_MODEL=llama3.1
OLLAMA_API_URL=http://localhost:11434
OLLAMA_TIMEOUT=300

# Optional RapidAPI fallback for YouTube downloads.
# Leave empty to disable the fallback.
RAPIDAPI_KEY=

# Optional Google OAuth credential rotation.
# Use local paths only. Separate multiple paths with semicolons on Windows
# or colons on macOS/Linux.
GOOGLE_CREDENTIALS_FILES=

# Clip selection defaults
MIN_CLIP_DURATION=30
MAX_CLIP_DURATION=120
NUM_CLIPS_TO_IDENTIFY=5

# Video editing defaults
OUTPUT_RESOLUTION=1080p
OUTPUT_FORMAT=vertical

# GPU settings
USE_GPU=false
CUDA_VISIBLE_DEVICES=
